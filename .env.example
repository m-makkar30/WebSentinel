# Copy this file to `.env` and fill in values: `cp .env.example .env`
# `.env` is gitignored — never commit real secrets.

# ---- PostgreSQL (pgvector) ----
POSTGRES_USER=websentinel
POSTGRES_PASSWORD=websentinel
POSTGRES_DB=websentinel
# Host port published to your machine (container always listens on 5432).
POSTGRES_PORT=5432
# Hostname used by app services inside the compose network.
POSTGRES_HOST=postgres

# ---- Redis ----
# Host port published to your machine (container always listens on 6379).
REDIS_PORT=6379
REDIS_HOST=redis

# ---- Django ----
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://websentinel:websentinel@postgres:5432/websentinel
# Host port the backend API is published on.
BACKEND_PORT=8000

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- NVIDIA NIM (LLM provider) ----
# REQUIRED for LLM features. Create a key at https://build.nvidia.com (prefixed
# `nvapi-`). Leave unset to disable LLM features (pipeline falls back to rules).
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Model routing: cheaper model for routine extraction, stronger for assessment.
LLM_MODEL_EXTRACT=meta/llama-3.1-8b-instruct
LLM_MODEL_ASSESS=meta/llama-3.3-70b-instruct
LLM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
LLM_MAX_TOKENS=1024
